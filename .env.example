# ──────────────────────────────────────────────
# MANÁ BACKEND – Variables de entorno
# Copiá este archivo a .env y completá los valores
# ──────────────────────────────────────────────

PORT=3000

# Firebase Admin SDK
# Descargá el JSON desde Firebase Console → Configuración del proyecto → Cuentas de servicio
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# JWT separado para el panel de plataforma (si no se define, usa JWT_SECRET)
PLATFORM_JWT_SECRET=YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
BACKEND_URL=https://tu-api.onrender.com
# Dominio del tenant activo en desarrollo local (el mismo que está en la colección tenants)
DEV_TENANT=tudominio.app

CORS_ORIGIN=http://localhost:4200

